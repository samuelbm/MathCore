{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build All",
      "type": "shell",
      "command": "cmake --build build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Run Unit Tests",
      "type": "shell",
      "command": "./build/test_matrix --gtest_catch_exceptions=1",
      "dependsOn": "Build All",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Run Example",
      "type": "shell",
      "command": "./build/example",
      "dependsOn": "Run Unit Tests",
      "group": "test",
      "problemMatcher": []
    }
  ]
}